<Window x:Class="AceAffinity.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AceAffinity.UI.Views"
        mc:Ignorable="d"
        Title="AceAffinity"
        Height="200" Width="400">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Target Process:" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox x:Name="ProcessNameTextBox" Width="150" Text="ACE-Tray"/>
            </StackPanel>
            <Button x:Name="OptimizeButton" Content="Apply Optimization" Width="150" Margin="0,20,0,0" Click="OptimizeButton_Click"/>
            <TextBlock x:Name="StatusTextBlock" Text="Status: Idle" Margin="0,10,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
