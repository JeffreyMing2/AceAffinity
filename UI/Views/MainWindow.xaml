<Window x:Class="AceAffinity.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AceAffinity.UI.Views"
        mc:Ignorable="d"
        Title="ACE 进程资源隔离优化工具"
        Height="280" Width="450"
        Background="#F3F3F3"
        Icon="../Assets/logo.png"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Area -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15,10">
            <DockPanel LastChildFill="True">
                <Button x:Name="AboutButton" 
                        Content="?" 
                        DockPanel.Dock="Right"
                        Width="24" Height="24" 
                        Background="Transparent" 
                        Foreground="White" 
                        BorderThickness="0" 
                        FontSize="14" 
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="AboutButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock Text="ACE 进程资源隔离优化工具" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Row="1" Background="White" Margin="15" Padding="20" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="目标进程:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Medium"/>
                    <TextBox x:Name="ProcessNameTextBox" Grid.Column="1" Padding="8,5" Text="ACE-Tray" BorderBrush="#DDDDDD" BorderThickness="1"/>
                </Grid>

                <Button x:Name="OptimizeButton" 
                        Content="应用优化策略" 
                        Padding="15,8" 
                        Background="#2196F3" 
                        Foreground="White" 
                        BorderThickness="0" 
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="OptimizeButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock x:Name="StatusTextBlock" 
                           Text="状态: 等待中" 
                           Margin="0,15,0,0" 
                           Foreground="#666666" 
                           HorizontalAlignment="Center" 
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="15,5,15,10">
            <DockPanel LastChildFill="True">
                <TextBlock Text="明明Uncle" DockPanel.Dock="Right" Foreground="#999999" FontSize="10" VerticalAlignment="Center"/>
                <TextBlock Text="v1.0.0" Foreground="#999999" FontSize="10" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
