<Window x:Class="AceAffinity.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AceAffinity.UI.Views"
        mc:Ignorable="d"
        Title="关于 ACE 进程隔离工具"
        Height="320" Width="400"
        Background="White"
        Icon="../Assets/logo.png"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- App Icon/Logo Placeholder -->
            <Border Width="80" Height="80" CornerRadius="8" Margin="0,0,0,15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                </Border.Effect>
                <Image Source="../Assets/logo.png" Stretch="Uniform"/>
            </Border>

            <TextBlock Text="ACE 进程资源隔离工具" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="版本 v1.0.0" Foreground="#999999" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="ACE 进程资源隔离工具是一款轻量级的 Windows 性能优化工具，通过调整进程的亲和性和优先级来优化系统性能。" 
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="#333333" Margin="0,0,0,15"/>

            <TextBlock FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Hyperlink NavigateUri="https://github.com/JeffreyMing2/AceAffinity" RequestNavigate="Hyperlink_RequestNavigate">
                    项目地址: https://github.com/JeffreyMing2/AceAffinity
                </Hyperlink>
            </TextBlock>

            <Separator Background="#EEEEEE" Margin="0,0,0,15"/>

            <StackPanel Orientation="Vertical">
                <TextBlock Text="作者: 明明Uncle" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="© 2026 明明Uncle. 保留所有权利。" Foreground="#999999" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>

            <Button Content="关闭" Margin="0,20,0,0" Padding="20,5" HorizontalAlignment="Center" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
