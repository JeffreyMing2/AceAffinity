<Window x:Class="AceAffinity.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AceAffinity.UI.Views"
        mc:Ignorable="d"
        Title="About ACE Affinity"
        Height="300" Width="400"
        Background="White"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- App Icon/Logo Placeholder -->
            <Border Width="60" Height="60" Background="#2196F3" CornerRadius="30" Margin="0,0,0,15">
                <TextBlock Text="ACE" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="ACE Affinity" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="v1.0.0" Foreground="#999999" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="ACE Affinity is a lightweight process isolation tool designed to optimize system performance by adjusting process affinity and priority." 
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="#333333" Margin="0,0,0,20"/>

            <Separator Background="#EEEEEE" Margin="0,0,0,20"/>

            <StackPanel Orientation="Vertical">
                <TextBlock Text="Developed by ACE Team" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="© 2026 ACE Team. All rights reserved." Foreground="#999999" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>

            <Button Content="Close" Margin="0,20,0,0" Padding="20,5" HorizontalAlignment="Center" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
